{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FlyTunnel",
  "version": "0.1.0",
  "identifier": "com.flytunnel.client",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "FlyTunnel",
        "width": 580,
        "height": 740,
        "minWidth": 520,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
